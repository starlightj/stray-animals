/* 全局样式 - 暖色调动物主题 */
page {
  background: #fdf6ec;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #2c3e50;
}

/* 卡片 */
.card {
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  box-shadow: 0 3rpx 12rpx rgba(180, 120, 60, 0.10);
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(230, 126, 34, 0.06);
}
.card-title {
  color: #5a3e1b;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #fef0e0;
}

/* 标签 */
.tag {
  display: inline-block;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  padding: 4rpx 18rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 40rpx;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 3rpx 8rpx rgba(230,126,34,0.20);
}
.btn-primary {
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
}
.btn-danger {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
}
.btn-secondary {
  background: #b0a090;
  color: #fff;
  box-shadow: none;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-weight: 600;
  color: #5a3e1b;
  font-size: 26rpx;
}
.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #f0d5b0;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: #fefcf9;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: #e67e22;
}

/* 网格 */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #b0a090;
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #b0a090;
  font-size: 28rpx;
}

/* 搜索条 */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.search-input {
  flex: 1;
  padding: 16rpx 24rpx;
  border: 2rpx solid #f0d5b0;
  border-radius: 8rpx;
  background: #fefcf9;
  font-size: 26rpx;
}
.search-picker {
  padding: 16rpx 24rpx;
  border: 2rpx solid #f0d5b0;
  border-radius: 8rpx;
  background: #fefcf9;
  font-size: 26rpx;
}
