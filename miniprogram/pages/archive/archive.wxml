<view class="page">
  <view class="card">
    <view class="card-title">📋 动物档案库</view>

    <!-- 搜索 -->
    <view class="search-bar">
      <input class="search-input" placeholder="搜索名称或特征..." model:value="{{keyword}}" bindinput="onSearch" />
      <picker class="search-picker" range="{{speciesFilter}}" bindchange="onFilter">
        <view>{{currentFilter || '全部物种'}}</view>
      </picker>
    </view>

    <!-- 列表 -->
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:elif="{{list.length === 0}}" class="empty">没有找到匹配的动物</view>
    <view wx:else class="animal-grid">
      <view class="animal-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
        <image src="{{item.imageUrl}}" class="animal-img" mode="aspectFill" />
        <text class="animal-name">{{item.name || '未命名'}}</text>
        <view class="animal-info">
          <text class="tag">{{item.species}}</text>
          <text class="animal-color">{{item.color}}</text>
        </view>
        <text class="animal-features">{{item.features || '暂无描述'}}</text>
        <text class="animal-address">📍 {{item.location.address}}</text>
      </view>
    </view>
  </view>
</view>
