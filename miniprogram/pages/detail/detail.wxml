<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{!animal}}" class="empty">动物不存在</view>

  <view wx:else class="card" style="padding:0;overflow:hidden;">
    <image src="{{animal.imageUrl}}" class="detail-img" mode="aspectFill" />

    <view style="padding:24rpx;">
      <text class="detail-name">{{animal.name || '未命名'}}</text>

      <view class="detail-grid">
        <view class="detail-item">
          <text class="detail-label">物种</text>
          <text class="detail-value">{{animal.species}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">毛色</text>
          <text class="detail-value">{{animal.color}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">AI 识别</text>
          <text class="detail-value">
            {{animal.animal_type === '猫' ? '🐱 猫' : animal.animal_type === '狗' ? '🐶 狗' : '未识别'}}
          </text>
        </view>
        <view class="detail-item">
          <text class="detail-label">发现地点</text>
          <text class="detail-value">{{animal.location.address}}</text>
        </view>
      </view>

      <view class="detail-section">
        <text class="detail-section-title">特征描述</text>
        <text class="detail-section-body">{{animal.features || '暂无描述'}}</text>
      </view>

      <text class="detail-time">📅 登记时间：{{animal.createdAt}}</text>

      <!-- 操作按钮 -->
      <view class="btn-group" style="margin-top:24rpx;">
        <button class="btn" style="flex:1" bindtap="goAdopt">🏠 申请领养</button>
        <button class="btn-secondary" style="flex:1" bindtap="goComments">💬 评论</button>
      </view>
      <view class="btn-group" style="margin-top:12rpx;">
        <button class="btn btn-edit-sm" style="flex:1" bindtap="goEdit">✏️ 编辑</button>
        <button class="btn-secondary" style="flex:1" bindtap="goBack">返回</button>
      </view>
    </view>
  </view>
</view>
