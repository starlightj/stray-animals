.page { padding: 20rpx; }

.detail-img {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #5a3e1b;
  display: block;
  margin-bottom: 20rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  background: #fefcf9;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f5ede4;
  margin-bottom: 20rpx;
}
.detail-item { }
.detail-label { font-size: 22rpx; color: #7a5a2e; font-weight: 600; display: block; margin-bottom: 4rpx; }
.detail-value { font-size: 28rpx; color: #2c3e50; display: block; }

.detail-section { margin-bottom: 16rpx; }
.detail-section-title { font-size: 24rpx; color: #7a5a2e; font-weight: 600; display: block; margin-bottom: 6rpx; }
.detail-section-body { font-size: 26rpx; color: #5a3e1b; display: block; line-height: 1.6; }

.detail-time { font-size: 22rpx; color: #b0a090; display: block; }

.btn-group { display: flex; gap: 16rpx; }
.btn-edit-sm { background: linear-gradient(135deg, #8e7cc3, #6c5ce7) !important; }
