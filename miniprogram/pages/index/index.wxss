.page {
  padding: 20rpx;
}

/* 统计 */
.stats-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}
.stat-card {
  flex: 1;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  padding: 24rpx 16rpx;
  border-radius: 14rpx;
  text-align: center;
  box-shadow: 0 4rpx 14rpx rgba(230,126,34,0.25);
}
.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}
.stat-label {
  font-size: 22rpx;
  opacity: 0.88;
  margin-top: 6rpx;
  display: block;
}

/* 横向滚动 */
.animal-scroll {
  width: 100%;
  white-space: nowrap;
  padding-bottom: 10rpx;
}
.animal-scroll-inner {
  display: flex;
  gap: 18rpx;
}
.animal-card-sm {
  display: inline-block;
  width: 240rpx;
  background: #fefcf9;
  border-radius: 12rpx;
  padding: 14rpx;
  border: 1rpx solid #f0d5b0;
  white-space: normal;
}
.animal-img-sm {
  width: 212rpx;
  height: 160rpx;
  border-radius: 8rpx;
  object-fit: cover;
}
.animal-name-sm {
  font-size: 26rpx;
  font-weight: 600;
  color: #5a3e1b;
  display: block;
  margin-top: 8rpx;
}
.animal-tags {
  margin-top: 6rpx;
}
.tag-color {
  background: #b0a090 !important;
}

/* 快速入口 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}
.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 3rpx 12rpx rgba(180,120,60,0.10);
  border: 1rpx solid rgba(230,126,34,0.06);
}
.action-icon {
  font-size: 44rpx;
  display: block;
}
.action-text {
  font-size: 24rpx;
  color: #5a3e1b;
  margin-top: 8rpx;
  display: block;
}
