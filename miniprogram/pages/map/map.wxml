<view class="page">
  <view class="card">
    <view class="card-title">🗺️ 动物位置分布</view>
    <picker class="search-picker" range="{{speciesFilter}}" bindchange="onFilter" style="width:100%;margin-bottom:20rpx;">
      <view>{{currentFilter || '全部物种'}}</view>
    </picker>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:elif="{{list.length === 0}}" class="empty">暂无数据</view>

    <view class="map-list" wx:else>
      <view class="map-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
        <image src="{{item.imageUrl}}" class="map-card-img" mode="aspectFill" />
        <view class="map-card-info">
          <text class="map-card-name">{{item.name || '未命名'}}</text>
          <text class="tag">{{item.species}}</text>
          <text class="map-card-addr">📍 {{item.location.address}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
