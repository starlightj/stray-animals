.page { padding: 20rpx; }

.map-list { display: flex; flex-direction: column; gap: 16rpx; }

.map-card {
  display: flex;
  gap: 16rpx;
  background: #fff;
  padding: 16rpx;
  border-radius: 14rpx;
  box-shadow: 0 3rpx 12rpx rgba(180,120,60,0.10);
  border: 1rpx solid rgba(230,126,34,0.06);
}
.map-card-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  object-fit: cover;
  flex-shrink: 0;
}
.map-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.map-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5a3e1b;
}
.map-card-addr {
  font-size: 22rpx;
  color: #b0a090;
  margin-top: auto;
}
