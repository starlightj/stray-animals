.page { padding: 20rpx; }
.page-desc { font-size: 24rpx; color: #b0a090; display: block; margin-bottom: 20rpx; }

.adopt-list { display: flex; flex-direction: column; gap: 16rpx; }

.adopt-card {
  display: flex;
  gap: 14rpx;
  background: #fff;
  padding: 16rpx;
  border-radius: 14rpx;
  box-shadow: 0 3rpx 12rpx rgba(180,120,60,0.10);
  border: 1rpx solid rgba(230,126,34,0.06);
  flex-wrap: wrap;
  position: relative;
}
.adopt-img {
  width: 180rpx; height: 180rpx;
  border-radius: 10rpx;
  object-fit: cover;
  flex-shrink: 0;
}
.adopt-info { flex: 1; min-width: 0; }
.adopt-name { font-size: 28rpx; font-weight: 600; color: #5a3e1b; display: block; }
.adopt-tags { margin-top: 6rpx; }
.tag-color { background: #b0a090 !important; }
.adopt-features { font-size: 22rpx; color: #8a7a6a; display: block; margin-top: 6rpx; }
.adopt-addr { font-size: 20rpx; color: #b0a090; display: block; margin-top: 4rpx; }

.btn-adopt {
  width: 100%;
  padding: 14rpx;
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

/* 弹窗 */
.modal {
  position: fixed; top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(90,62,27,0.45);
  z-index: 1000;
  display: none;
  align-items: flex-end;
  justify-content: center;
}
.modal.active { display: flex; }
.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 30rpx;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #5a3e1b; }
.modal-close { font-size: 36rpx; color: #b0a090; padding: 10rpx; }
.modal-footer { display: flex; gap: 16rpx; margin-top: 24rpx; }
