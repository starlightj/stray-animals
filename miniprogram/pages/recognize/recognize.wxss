.page { padding: 20rpx; }

/* 上传区 */
.upload-area {
  border: 2.5rpx dashed #f0c8a0;
  padding: 60rpx 20rpx;
  text-align: center;
  border-radius: 14rpx;
  background: #fefcf9;
  margin-bottom: 20rpx;
}
.upload-icon { font-size: 64rpx; display: block; margin-bottom: 12rpx; }
.upload-text { font-size: 30rpx; font-weight: 600; color: #7a5a2e; display: block; }
.upload-hint { font-size: 22rpx; color: #b0a090; margin-top: 10rpx; display: block; }

/* 预览 */
.preview-area { margin-bottom: 20rpx; }
.preview-img { width: 100%; height: 400rpx; border-radius: 12rpx; }
.preview-actions { margin-top: 12rpx; text-align: center; }

/* 识别中 */
.recognizing { text-align: center; padding: 30rpx; }
.rec-icon { font-size: 48rpx; display: block; }
.rec-text { font-size: 26rpx; color: #b87c3a; margin-top: 8rpx; display: block; }

/* AI 识别徽章 */
.ai-badge {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 14rpx;
}
.ai-badge.cat { background: linear-gradient(135deg,#fff3e0,#ffe0b2); color: #d35400; border: 2rpx solid #f39c12; }
.ai-badge.dog { background: linear-gradient(135deg,#e0f7fa,#b2ebf2); color: #00695c; border: 2rpx solid #26a69a; }
.ai-badge.uncertain { background: linear-gradient(135deg,#f5f5f5,#e0e0e0); color: #757575; border: 2rpx solid #bdbdbd; }
.ai-icon { font-size: 60rpx; display: block; margin-bottom: 6rpx; }
.ai-label { font-size: 36rpx; font-weight: 700; display: block; }
.ai-conf { font-size: 22rpx; opacity: 0.8; margin-top: 4rpx; display: block; }
.conf-bar { width: 100%; height: 8rpx; background: #f0e8e0; border-radius: 4rpx; margin-top: 10rpx; overflow: hidden; }
.conf-fill { height: 100%; border-radius: 4rpx; transition: width 0.5s; }
.conf-fill.high { background: linear-gradient(90deg,#27ae60,#2ecc71); }
.conf-fill.medium { background: linear-gradient(90deg,#f39c12,#f1c40f); }
.conf-fill.low { background: linear-gradient(90deg,#e74c3c,#e67e22); }

/* 结果卡片 */
.result-card {
  background: #fefcf9;
  border: 1.5rpx solid #f0c8a0;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
}
.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5ede4;
}
.result-row:last-child { border-bottom: none; }
.result-key { color: #8a7a6a; font-size: 26rpx; }
.result-val { color: #5a3e1b; font-size: 26rpx; font-weight: 500; }

/* 表单 */
.form-section { margin-top: 20rpx; }
.result-section { margin-top: 20rpx; }
