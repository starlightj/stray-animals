.page { padding: 20rpx; }

.post-box {
  background: #fefcf9;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f0d5b0;
  margin-bottom: 24rpx;
}

.comment-list { display: flex; flex-direction: column; gap: 16rpx; }

.comment-item {
  background: #fefcf9;
  padding: 18rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f5ede4;
}
.comment-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.comment-avatar {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.comment-nickname { font-size: 26rpx; font-weight: 500; color: #5a3e1b; flex:1; }
.comment-time { font-size: 20rpx; color: #b0a090; flex-shrink:0; }
.comment-content { font-size: 26rpx; color: #2c3e50; line-height: 1.6; }
