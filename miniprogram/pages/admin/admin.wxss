.page { padding: 20rpx; }

.admin-list { display: flex; flex-direction: column; gap: 12rpx; }
.admin-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f5ede4;
}
.admin-img {
  width: 80rpx; height: 80rpx;
  border-radius: 10rpx;
  object-fit: cover;
  flex-shrink: 0;
}
.admin-info { flex: 1; min-width: 0; }
.admin-name { font-size: 26rpx; font-weight: 600; color: #5a3e1b; display: block; }
.admin-desc { font-size: 22rpx; color: #8a7a6a; display: block; margin-top: 4rpx; }

.admin-actions { display: flex; gap: 8rpx; flex-shrink: 0; }
.btn-sm {
  width: 60rpx; height: 60rpx;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
.btn-edit { background: #fef5e7; color: #e67e22; }
.btn-del { background: #fde8e8; color: #e74c3c; }

/* 弹窗 */
.modal {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(90,62,27,0.45);
  z-index: 1000;
  display: none;
  align-items: flex-end;
  justify-content: center;
}
.modal.active { display: flex; }
.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 30rpx;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #5a3e1b; }
.modal-close { font-size: 36rpx; color: #b0a090; padding: 10rpx; }
.modal-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
