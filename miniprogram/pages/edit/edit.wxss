.page { padding: 20rpx; }

.edit-preview {
  width: 100%;
  height: 260rpx;
  border-radius: 12rpx;
  object-fit: cover;
  margin-bottom: 20rpx;
  border: 2rpx solid #f0d5b0;
}

.btn-upload {
  width: 100%;
  padding: 16rpx;
  background: linear-gradient(135deg, #8e7cc3, #6c5ce7);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.btn-group { display: flex; gap: 16rpx; margin-top: 24rpx; }
